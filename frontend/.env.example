# The Tribunal frontend environment template.
# Copy to frontend/.env.local for local development.

# Backend API origin used by Next.js rewrites and WebSocket helpers.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional billing page display price. Escape the literal dollar for Next.js dotenv expansion.
NEXT_PUBLIC_PLAN_PRICE=\$297/month

# Optional Sentry browser/server DSN. Leave blank to disable local reporting.
NEXT_PUBLIC_SENTRY_DSN=

# Optional Sentry source-map upload token for CI/release builds.
SENTRY_AUTH_TOKEN=

# Optional local override for the Prestyj pixel project key.
EZCODER_PIXEL_KEY=

# Optional Playwright target. Leave blank to let npm run e2e start Next.js locally.
PLAYWRIGHT_BASE_URL=

# Optional seeded test user for authenticated Playwright specs.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
